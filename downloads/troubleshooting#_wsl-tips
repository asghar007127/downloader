<span class="line"><span style="--shiki-dark:#DCDCAA;--shiki-light:#795E26">ssh-copy-id</span><span style="--shiki-dark:#569CD6;--shiki-light:#0000FF"> -i</span><span style="--shiki-dark:#CE9178;--shiki-light:#A31515"> "</span><span style="--shiki-dark:#9CDCFE;--shiki-light:#001080">$PUBKEYPATH</span><span style="--shiki-dark:#CE9178;--shiki-light:#A31515">"</span><span style="--shiki-dark:#CE9178;--shiki-light:#A31515"> "</span><span style="--shiki-dark:#9CDCFE;--shiki-light:#001080">$USER_AT_HOST</span><span style="--shiki-dark:#CE9178;--shiki-light:#A31515">"</span></span>
